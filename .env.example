# Firebase Web config (Console > Configurações do projeto > Seus apps > Web)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK service account JSON, inteiro em base64 (uma linha só).
# Gerar em: Console > Configurações do projeto > Contas de serviço > Gerar nova chave privada
# Depois: base64 -w0 service-account.json (Linux) ou base64 -i service-account.json (Mac)
FIREBASE_ADMIN_CREDENTIALS_BASE64=

# Senha do painel admin, como hash bcrypt (não a senha em texto puro).
# Gerar com: npx tsx -e "import bcrypt from 'bcryptjs'; console.log(bcrypt.hashSync('SUA_SENHA', 10))"
# IMPORTANTE: escape todo "$" do hash como "\$" neste arquivo — o Next.js expande
# variáveis estilo ${VAR} em .env, e um hash bcrypt tem vários "$" que seriam
# interpretados (e corrompidos) como referências a variáveis inexistentes.
# Ex: $2b$10$abc... deve virar \$2b\$10\$abc...
ADMIN_PASSWORD_HASH=

# Segredo aleatório para assinar o cookie de sessão do admin (ex: openssl rand -base64 32)
SESSION_SECRET=

# A chave Pix, o número de WhatsApp e o conteúdo da página inicial NÃO ficam
# em variáveis de ambiente — são configurados depois do deploy, direto pelo
# painel em /admin/configuracoes (ficam salvos no Firestore). Rode
# `npm run seed` uma vez para criar a rifa de exemplo antes disso.

# Regras de negócio (opcionais, têm valor padrão)
RESERVATION_TTL_MINUTES=30
MAX_TICKETS_PER_ORDER=50
NEXT_PUBLIC_RESERVATION_TTL_MINUTES=30
MIN_DONATION_CENTS=500

# Segredo para proteger a rota de cron (Vercel envia este valor automaticamente
# como "Authorization: Bearer <CRON_SECRET>" quando a env var está configurada)
CRON_SECRET=
